{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "group:allNonMajor"
    ],
    "enabledManagers": [
        "gradle"
    ],
    "timezone": "Etc/UTC",
    "schedule": [
        "after 00:00 and before 04:00 on Wednesday"
    ],
    "dependencyDashboard": true,
    "prConcurrentLimit": 5,
    "prHourlyLimit": 2,
    "labels": [
        "dependencies"
    ],
    "reviewers": [
        "sleidig"
    ],
    "packageRules": [
        {
            "matchUpdateTypes": [
                "major"
            ],
            "draftPR": true,
            "dependencyDashboardApproval": true,
            "labels": [
                "dependencies",
                "major-update"
            ]
        },
        {
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "groupName": "weekly-non-major-updates",
            "automerge": false
        }
    ]
}